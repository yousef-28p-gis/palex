# ===== FILE: c:\Users\PC\Desktop\p2p-backend\.env.example =====

# ==================== قاعدة البيانات ====================
DATABASE_URL="mysql://root:password@localhost:3306/p2pescrow"

# ==================== JWT ====================
JWT_SECRET=change-this-to-random-string-64-chars
JWT_REFRESH_SECRET=change-this-to-random-string-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==================== السيرفر ====================
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ==================== Vault (المفتاح الرئيسي للخزنة) ====================
# ⚠️ هذا المفتاح يحمي جميع المفاتيح الخاصة الأخرى
# يجب حفظه في مكان آمن جداً (مثل مدير كلمات المرور)
# طوله 64 حرف سداسي عشري (Hex)
VAULT_MASTER_KEY=change-this-to-64-hex-characters-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== إعدادات البلوكتشين (سيتم تخزينها في Vault) ====================
# لا تضع المفاتيح الخاصة هنا! سيتم إضافتها عبر Vault
USE_TESTNET=false
TRON_PROVIDER=https://api.trongrid.io
BSC_PROVIDER=https://bsc-dataseed.binance.org
USDT_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
BSC_USDT_CONTRACT_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# ==================== المهلات ====================
SELLER_DEPOSIT_TIMEOUT=30
BUYER_PAYMENT_TIMEOUT=30
ENCRYPTION_KEY=01234567890123456789012345678901

# ==================== إعدادات SMTP (اختياري) ====================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=